      "parameters": {
        "jsCode": "// Input dal nodo OpenAI\nconst raw = $input.first().json;\n\n// Metadati dalla fase di estrazione (upstream)\nconst estrai = $('ðŸ—‚ï¸ Estrai e Valida Dati').first().json;\n\n// Parsing risposta AI\nlet parsed;\ntry {\n  const content = raw.message?.content\n    || raw.choices?.[0]?.message?.content\n    || raw.output?.[0]?.content?.[0]?.text\n    || JSON.stringify(raw);\n  parsed = JSON.parse(content);\n} catch (e) {\n  throw new Error('OpenAI non ha restituito JSON valido: ' + String(\n    raw.message?.content || raw.output?.[0]?.content?.[0]?.text || raw\n  ).substring(0, 300));\n}\n\nconst platforms = ['linkedin', 'facebook', 'instagram', 'tiktok'];\nconst generatedPosts = platforms.map(platform => ({\n  platform,\n  content: parsed[platform]?.content || '',\n  hashtags: parsed[platform]?.hashtags || [],\n}));\n\nconst preview = generatedPosts\n  .map(p => p.platform.toUpperCase() + '\\n' + p.content + '\\n' + p.hashtags.join(' '))\n  .join('\\n\\n---\\n\\n');\n\nreturn {\n  newsId: estrai.newsId || parsed.newsId || '',\n  title: estrai.title || parsed.title || '',\n  summary: estrai.summary || parsed.summary || '',\n  source: estrai.source || parsed.source || '',\n  link: estrai.link || parsed.link || '',\n  generatedPosts,\n  blogPost: '',\n  formattedPreview: preview,\n  postCount: generatedPosts.length,\n  platforms: generatedPosts.map(p => p.platform),\n    imagePrompt: parsed.imagePrompt || '',\n};"
