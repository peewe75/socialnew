# ============ AI PROVIDER ============
AI_PROVIDER=openrouter              # Opzioni: openai, openrouter, anthropic
AI_API_KEY=sk-or-xxx_your_key       # OpenRouter, OpenAI, o Anthropic key

# ============ PERPLEXITY (News Collection) ============
PERPLEXITY_API_KEY=ppl_xxx_your_key

# ============ BLOTATO (Multi-Platform Publishing) ============
BLOTATO_API_KEY=blotato_xxx_your_key
BLOTATO_BASE_URL=https://backend.blotato.com/v2

# ============ WEBHOOK CONFIGURATION ============
APPROVAL_WEBHOOK_URL=http://localhost:4000/webhook/approval
WEBHOOK_SECRET=change_this_secret

# ============ DATABASE (Supabase PostgreSQL) ============
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ============ CLERK AUTH ============
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ============ SERVER ============
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
