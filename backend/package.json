{
  "name": "news-to-social-automation-backend",
  "version": "1.0.0",
  "description": "News collection, AI generation, and multi-platform publishing with Blotato",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
