{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*", "database/**/*", "prisma/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
